rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function validUserDoc() {
      let d = request.resource.data;
      return d.username is string
          && d.username.size() >= 2
          && d.username.size() <= 30
          && d.bio is string
          && d.bio.size() <= 500
          && d.vibes is list
          && d.vibes.size() <= 10;
    }

    // ── Users ─────────────────────────────────────────────────────────────

    match /users/{uid} {
      // Anyone signed in can read public profiles
      allow read: if isSignedIn();
      // Only the owner can write their own profile; input is validated
      allow write: if isSignedIn() && isOwner(uid) && validUserDoc();
    }

    // ── Journal ───────────────────────────────────────────────────────────

    match /journals/{uid}/entries/{entryId} {
      allow read, write: if isSignedIn() && isOwner(uid);
    }

    // ── Likes ─────────────────────────────────────────────────────────────

    match /likes/{toUid}/received/{fromUid} {
      // Anyone signed in can send a like
      allow create: if isSignedIn() && request.auth.uid == fromUid;
      // Only the recipient can read their likes
      allow read: if isSignedIn() && isOwner(toUid);
      // No updates; likes can only be created
      allow update: if false;
      // Sender can un-like
      allow delete: if isSignedIn() && request.auth.uid == fromUid;
    }

    // ── Chats ─────────────────────────────────────────────────────────────

    match /chats/{chatId} {
      function isParticipant() {
        return isSignedIn()
            && request.auth.uid in resource.data.participants;
      }
      function isParticipantOnCreate() {
        return isSignedIn()
            && request.auth.uid in request.resource.data.participants;
      }

      allow read:   if isParticipant();
      allow create: if isParticipantOnCreate();
      allow update: if isParticipant();
      allow delete: if false; // chats are never deleted via client

      match /messages/{msgId} {
        allow read:   if isSignedIn()
                        && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isSignedIn()
                        && request.resource.data.senderId == request.auth.uid
                        && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow update, delete: if false;
      }
    }
  }
}
